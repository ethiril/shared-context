# Per-team / per-instance content — never part of the shareable framework.
/features/
/AGENTS.md
/dashboard.html
/index.html

# Generated doc-page siblings (re-rendered by `bin/render-dashboard.mjs`
# alongside `dashboard.html` so clicking from `index.html` lands on styled
# pages instead of raw markdown). Source-of-truth `.md` files stay tracked.
/AGENTS.html
/README.html
/framework/README.html
/framework/CONVENTIONS.html
/framework/orchestrator/brief.html
/framework/commands/*.html
/framework/templates/*.html
/framework/examples/index.html
/globals
# Local Claude Code config (contains absolute paths).
.claude/settings.local.json

# Runtime artifacts produced by the orchestrator hook.
framework/orchestrator/.last-run.log

# Diagnostics-mode traces (opt-in hook-diagnostics.sh). Per-feature traces live
# under features/<slug>/.diagnostics/ (already covered by /features/ above);
# this covers the root-level session-attribution staging dir.
/.diagnostics/

# OS noise.
.DS_Store

# Local Python venvs (e.g. tiktoken venv used by framework/bin/measure-formats.py).
.venv*/
